#################################################################
#											 Makefile
#		Makefile to build exe
#################################################################
.PHONY: clean
# Define the compiler variable
CC = g++

# List all .cpp files, .o files, .a files and .so files
SRCS = Main.cpp Fun.cpp FunN.cpp
OBJS = Main.o
STATIC_LIBRARIES = Fun.a
SHARED_LIBRARIES = FunN.so
TARGET = Main.exe

# Generate a list of .d files from SRCS
DEPS = $(SRCS:.cpp=.d)

# Default target:
$(TARGET): $(OBJS) $(STATIC_LIBRARIES) $(SHARED_LIBRARIES)
	$(CC) -o $@ $< -L. -lFun -lFunN

# The rule for # xyz.d is generated by xyz.cpp:
%.d: %.cpp
	rm -f $@;
	$(CC) -MM $< >$@.tmp; \
	sed 's,\($*\)\.o[ :]*,\1.o $@ : ,g' < $@.tmp > $@; \
	rm -f $@.tmp

# Pattern rules:
%.o: %.cpp
	$(CC) -c -fPIC -o $@ $<

# Rule to create the shared library from Fun.cpp
$(STATIC_LIBRARIES): Fun.o
	ar rcs libFun.a Fun.o

$(SHARED_LIBRARIES): FunN.o
	$(CC) -shared -o libFunN.so FunN.o

clean:
	@echo "Cleaning up ......"
	@-rm -rf *.exe *.o *.i *.s *.a *.so *.d # - prefix for ignoring errors
