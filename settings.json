{
   "clangd.arguments": [
      "--all-scopes-completion",
      "--background-index",
      "--clang-tidy",
      "--clang-tidy-checks=performance-*, bugprone-*, misc-*, google-*, modernize-*, readability-*, portability-*",
      "--compile-commands-dir=${workspaceFolder}",
      "--header-insertion=never",
      "--inlay-hints",
      "--completion-parse=auto",
      "--completion-style=detailed",
      "--enable-config",
      "--fallback-style=Webkit",
      "--function-arg-placeholders=true",
      "--header-insertion-decorators",
      "--pch-storage=memory",
      "--pretty",
      "--ranking-model=decision_forest"
   ],
   "C_Cpp.codeFolding": "disabled",
   "C_Cpp.suggestSnippets": false,
   "C_Cpp.enhancedColorization": "disabled",
   "C_Cpp.autocomplete": "disabled",
   "C_Cpp.hover": "disabled",
   "C_Cpp.default.enableConfigurationSquiggles": false,
   "C_Cpp.configurationWarnings": "disabled",
   "C_Cpp.errorSquiggles": "disabled",
   "C_Cpp.intelliSenseEngine": "disabled",
   "C_Cpp.configurationWarnings": "disabled",
   "C_Cpp.inlayHints.parameterNames.hideLeadingUnderscores": false,
   "C_Cpp.renameRequiresIdentifier": false,
   "C_Cpp.codeAnalysis.runAutomatically": false,
   "C_Cpp.formatting": "Disabled",
   "C_Cpp.debugger.useBacktickCommandSubstitution": true,
   "OpenCL.server.enable": false,
   "vscode-neovim.neovimExecutablePaths.darwin": "/usr/bin/nvim",
   "vscode-neovim.neovimInitVimPaths.darwin": "~/.config/nvim/init.vim",
   "editor.minimap.enabled": false
}
