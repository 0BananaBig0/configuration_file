{
   "languageserver": {
      "qml": {
         "command": "qmlls",
         "filetypes": [
            "qml"
         ]
      },
      "svlangserver": {
         "command": "svlangserver",
         "module": "/usr/lib/node_modules/@imc-trading/svlangserver/lib/svlangserver.js",
         "filetypes": [
            "systemverilog",
            "vhdl",
            "verilog"
         ],
         "settings": {
            "systemverilog.includeIndexing": [
               "**/*.{v,sv,svh}"
            ],
            "systemverilog.excludeIndexing": [
               "test/**/*.sv*"
            ],
            "systemverilog.defines": [],
            "systemverilog.launchConfiguration": "/usr/local/bin/verilator --lint-only --language 1364-2005",
            "systemverilog.formatCommand": "/usr/local/bin/verible-verilog-format"
         }
      }
   },
   "workspace.rootPatterns": [
      ".git",
      ".hg",
      ".projections.json",
      ".project",
      ".svn",
      ".root"
   ],
   "clangd.arguments": [
      "--all-scopes-completion",
      "--background-index",
      "--clang-tidy",
      "--completion-style=detailed",
      "--fallback-style=none",
      "--function-arg-placeholders=1",
      "--header-insertion=never",
      "--header-insertion-decorators",
      "--enable-config",
      "--j=12",
      "--pch-storage=memory",
      "--pretty"
   ],
   "coc.preferences.jumpCommand": "edit",
   "dialog.floatHighlight": "sym_hilight",
   "diagnostic.enable": false,
   "diagnostic.errorSign": "✗ ",
   "diagnostic.messageTarget": "echo",
   "diagnostic.virtualText": true,
   "diagnostic.warningSign": "⚡",
   "inlayHint.enable": false,
   "markdownlint.config": {
      "MD013": {
         "line_length": 100
      },
      "ignore_code_blocks": true
   },
   "perl.p::ls.enable": true,
   "perl.p::ls.logLevel": 2,
   "perl.p::ls.logFile": "/home/banana/.coc-perl.log",
   "prettier.formatterPriority": -1,
   "prettier.printWidth": 100,
   "prettier.proseWrap": "always",
   "signature.target": "echo",
   "suggest.autoTrigger": "none",
   "suggest.detailField": "preview",
   "suggest.maxCompleteItemCount": 18,
   "suggest.noselect": true,
   "suggest.selection": "recentlyUsedByPrefix",
   "suggest.virtualText": true,
   "suggest.triggerAfterInsertEnter": true
}
